<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
        CVE-2025-68161: Affects log4j-core Socket Appender (TLS hostname verification).
        Spring Boot only includes log4j-api (bridge), not log4j-core.
        Not exploitable without log4j-core on classpath.
    -->
    <suppress>
        <notes>False positive - affects log4j-core Socket Appender only, not log4j-api</notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-api@.*$</packageUrl>
        <cve>CVE-2025-68161</cve>
    </suppress>

    <!--
        CVE-2025-58056 / CVE-2025-58057: CVSS below 7.0 threshold, included for completeness.
        CVE-2025-55163, CVE-2026-33870, CVE-2026-33871: Netty overridden to 4.1.132.Final.
        Suppressing residual false positives from CPE matching on older version strings.
    -->
    <suppress>
        <notes>Netty upgraded to 4.1.132.Final - CPE false positive on version string matching</notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/.*@4\.1\..*$</packageUrl>
        <cve>CVE-2026-33871</cve>
    </suppress>
    <suppress>
        <notes>Netty upgraded to 4.1.132.Final - CPE false positive on version string matching</notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/.*@4\.1\..*$</packageUrl>
        <cve>CVE-2026-33870</cve>
    </suppress>
    <suppress>
        <notes>Netty upgraded to 4.1.132.Final - CPE false positive on version string matching</notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/.*@4\.1\..*$</packageUrl>
        <cve>CVE-2025-55163</cve>
    </suppress>
    <suppress>
        <notes>Netty upgraded to 4.1.132.Final - CPE false positive on version string matching</notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/.*@4\.1\..*$</packageUrl>
        <cve>CVE-2025-67735</cve>
    </suppress>

</suppressions>
